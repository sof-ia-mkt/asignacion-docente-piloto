# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# respaldos / volcados con datos personales de docentes — NUNCA commitear
respaldo_*.json
/backups/
*.bak-*
scripts/_audit*.mjs

# herramientas locales (config del servidor de previsualización, etc.)
.claude/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
